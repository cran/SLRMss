Package: SLRMss
Title: Symmetric Linear Regression Models for Small Samples
Version: 1.1.0
Authors@R: c(
    person("Ivonaldo S.", "da Silva-Júnior", , "ivosilvestresjr@gmail.com", role = c("aut", "cre")),
